# ---- Supabase ----
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key          # backend only — never ship to the browser; also validates user tokens

# ---- Model providers ----
ANTHROPIC_API_KEY=sk-ant-...                             # Claude answers questions
VOYAGE_API_KEY=pa-...                                    # Voyage AI embeds text (voyage-3.5, 1024-dim)

# ---- Optional overrides ----
ANSWER_MODEL=claude-opus-4-8
EMBED_MODEL=voyage-3.5
EMBED_DIM=1024
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=5

# ---- CORS ----
# Comma-separated. Include localhost for dev and your deployed frontend URL.
FRONTEND_URL=http://localhost:5173,https://your-frontend.vercel.app
